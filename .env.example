# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=0

# Public hostname (no protocol). Used to build redirect URIs and manifest URLs.
# For local dev: localhost:5000   |   Production: yourdomain.com
FLASK_RUN_HOST=yourdomain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB=anime_tracker

# ── Proxy Support (Optional) ──────────────────────────────────────────────────
# Routing all external API requests (MAL, AniList, Kitsu, Jikan) through a proxy.
# Supports HTTP, HTTPS, and SOCKS5 proxies. Perfect for bypassing rate limits.
# Examples:
# - Standard HTTP: http://username:password@proxyhost.com:8080
# - Local Gluetun/Glider VPN container proxy: http://glider:8443
PROXY_URL=

# ── MyAnimeList OAuth ─────────────────────────────────────────────────────────
# Create your app at: https://myanimelist.net/apiconfig
# Set redirect URI to: https://yourdomain.com/callback
MAL_CLIENT_ID=your_mal_client_id
MAL_CLIENT_SECRET=your_mal_client_secret

# ── AniList OAuth ─────────────────────────────────────────────────────────────
# Create your app at: https://anilist.co/settings/developer
# Set redirect URI to: https://yourdomain.com/anilist-callback
# Only the client ID needed — implicit grant, no secret required
ANILIST_CLIENT_ID=your_anilist_client_id

